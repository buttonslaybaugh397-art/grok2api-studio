# Browser stays same-origin by default (recommended).
# This avoids CORS completely for the standalone Studio.
VITE_API_BASE_URL=

# Upstream target for Vite proxy (dev/preview) and server.mjs reverse proxy.
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000

# Optional runtime override for server.mjs
# STUDIO_PROXY_TARGET=http://127.0.0.1:8000
# PORT=4175
